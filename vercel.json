{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' blob:; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://n8n-dev-calculadora.app.n8n.cloud https: http://localhost:* http://127.0.0.1:*; img-src 'self' data: blob:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/dist/styles.css",
      "destination": "/dist/styles.css"
    },
    {
      "source": "/dist/jspdf.umd.min.js",
      "destination": "/dist/jspdf.umd.min.js"
    },
    {
      "source": "/head-init.js",
      "destination": "/head-init.js"
    },
    {
      "source": "/calculadora.js",
      "destination": "/calculadora.js"
    },
    {
      "source": "/compliance.js",
      "destination": "/compliance.js"
    },
    {
      "source": "/benchmarking.js",
      "destination": "/benchmarking.js"
    },
    {
      "source": "/advanced-pricing.js",
      "destination": "/advanced-pricing.js"
    },
    {
      "source": "/risk-audit.js",
      "destination": "/risk-audit.js"
    },
    {
      "source": "/telemetry.js",
      "destination": "/telemetry.js"
    },
    {
      "source": "/privacidade.html",
      "destination": "/privacidade.html"
    },
    {
      "source": "/manifest.webmanifest",
      "destination": "/manifest.webmanifest"
    },
    {
      "source": "/negotiation-v21.js",
      "destination": "/negotiation-v21.js"
    },
    {
      "source": "/utils/storage.js",
      "destination": "/utils/storage.js"
    },
    {
      "source": "/hardening-v21.js",
      "destination": "/hardening-v21.js"
    },
    {
      "source": "/sw.js",
      "destination": "/sw.js"
    },
    {
      "source": "/offline.html",
      "destination": "/offline.html"
    },
    {
      "source": "/privacidade",
      "destination": "/privacidade/index.html"
    },
    {
      "source": "/privacidade/",
      "destination": "/privacidade/index.html"
    }
  ]
}

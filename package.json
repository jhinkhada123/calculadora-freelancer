{
  "name": "meuprimeiroapp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./dist/styles.css",
    "build:jspdf": "node -e \"const fs=require('fs'); fs.mkdirSync('dist',{recursive:true}); fs.copyFileSync('node_modules/jspdf/dist/jspdf.umd.min.js','dist/jspdf.umd.min.js')\"",
    "build": "npm run build:css && npm run build:jspdf",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "check": "node --check calculadora.js && node --check compliance.js",
    "validate": "npm run check && node validate-compute.mjs",
    "smoke:routes": "node scripts/smoke-routes.mjs"
  },
  "devDependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "jest": "29.7.0",
    "tailwindcss": "3.4.16"
  },
  "dependencies": {
    "jspdf": "2.5.1"
  }
}
